{
	"name": "anvilkit-components",
	"version": "0.0.2",
	"private": true,
	"license": "MIT",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"dev": "pnpm -r --parallel dev",
		"build": "pnpm -r build",
		"lint": "pnpm exec biome lint .",
		"format": "pnpm exec biome check --write .",
		"typecheck": "pnpm -r typecheck",
		"gen:component": "node ./turbo/generators/run-component-generator.mjs",
		"changeset": "changeset",
		"release": "changeset version && pnpm build && changeset publish"
	},
	"devDependencies": {
		"@anvilkit/biome-config": "workspace:*",
		"@anvilkit/tailwind-config": "workspace:*",
		"@anvilkit/typescript-config": "workspace:*",
		"@biomejs/biome": "2.4.9",
		"@puckeditor/core": "^0.21.1",
		"@turbo/gen": "^2.8.20",
		"@changesets/cli": "^2.30.0",
		"@rsbuild/plugin-react": "^1.4.6",
		"@rslib/core": "^0.20.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"turbo": "^2.8.20",
		"typescript": "^6.0.2"
	}
}
