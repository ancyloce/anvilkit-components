{
	"name": "@anvilkit/helps",
	"version": "0.0.1",
	"description": "Anvilkit Puck-native helps component.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./styles.css": "./dist/styles.css"
	},
	"files": [
		"dist",
		"README.md"
	],
	"license": "MIT",
	"sideEffects": [
		"./dist/index.js",
		"./dist/index.cjs",
		"**/*.css"
	],
	"scripts": {
		"build": "rslib build",
		"dev": "rslib build --watch",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@anvilkit/ui": "^0.0.1",
		"@puckeditor/core": "^0.21.1",
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0"
	},
	"devDependencies": {
		"@anvilkit/tailwind-config": "workspace:*",
		"@anvilkit/ui": "workspace:*"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"lucide-react": "^1.7.0"
	}
}
